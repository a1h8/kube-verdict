{
  "replicaCount": 2,
  "image": {
    "repository": "ghcr.io/acme/api",
    "tag": "v3.2.0",
    "pullPolicy": "IfNotPresent"
  },
  "resources": {
    "limits": {
      "memory": "128Mi",
      "cpu": "1"
    },
    "requests": {
      "memory": "64Mi",
      "cpu": "200m"
    }
  },
  "service": {
    "type": "ClusterIP",
    "port": 8080
  },
  "autoscaling": {
    "enabled": false
  }
}
