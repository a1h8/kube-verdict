# Add to your .env to enable Prometheus alert ingestion.
# KubeWhisperer reads /api/v1/alerts and label-matches firing alerts
# to K8s entities in the OntologyGraph.

PROMETHEUS_ENABLED=true
PROMETHEUS_URL=http://prometheus-operated.monitoring.svc:9090

# Optional: basic auth if Prometheus is behind a reverse proxy
# PROMETHEUS_USER=admin
# PROMETHEUS_PASSWORD=secret
