# Add to your .env to enable OTel trace ingestion.
# KubeWhisperer queries Tempo (or Jaeger) for error traces correlated
# to unhealthy pods, creates OtelTrace nodes, and adds a [TRACES] section
# to the LLM context window.

OTEL_ENABLED=true
OTEL_BACKEND=tempo          # or: jaeger
TEMPO_URL=http://tempo.monitoring.svc:3100

# For Jaeger instead:
# OTEL_BACKEND=jaeger
# JAEGER_URL=http://jaeger-query.monitoring.svc:16686
