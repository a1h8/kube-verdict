# Add to your .env to enable OTLP push-mode trace ingestion.
# KubeVerdict runs its own OTLP/HTTP receiver on :4318 — apps or an OTel
# Collector push spans to it; error traces are correlated to unhealthy pods
# and added as a [TRACES] section to the LLM context window.

OTEL_ENABLED=true
OTEL_BACKEND_TYPE=otlp     # tempo | jaeger | otlp
OTEL_LOOKBACK_HOURS=1

# OTLP push receiver (used when OTEL_BACKEND_TYPE=otlp)
OTLP_HOST=0.0.0.0
OTLP_PORT=4318
OTLP_MAX_TRACES=2000       # in-memory ring buffer size (traces kept)
