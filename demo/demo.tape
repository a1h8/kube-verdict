# KubeWhisperer — VHS demo tape
# Usage: vhs demo/demo.tape

Output demo/kubewhisperer-demo.gif

Set Shell      "bash"
Set FontSize   13
Set FontFamily "JetBrains Mono"
Set Width      1100
Set Height     750
Set Theme      "Dracula"
Set PlaybackSpeed 1
Set TypingSpeed 40ms
Set CursorBlink false
Set WaitTimeout 180s

Type "bash /Users/ah/workspaces/kubeWhisperer/demo/run_cli_demo.sh"
Enter

Sleep 120s
