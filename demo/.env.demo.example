# KubeWhisperer — demo environment
# Used by: demo/run_rca.py, demo/demo_webhook.py
# Requires: demo/cluster_setup.sh + demo/setup_observability.sh + demo/portforward.sh

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBECONFIG=~/.kube/config
KUBE_CONTEXT=k3d-kubewhisperer-demo
KUBE_NAMESPACES=kubewhisperer-demo

# ── LLM ───────────────────────────────────────────────────────────────────────
# Uncomment one:
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# LLM_PROVIDER=groq
# GROQ_API_KEY=

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/index.faiss
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Metrics server ────────────────────────────────────────────────────────────
METRICS_SERVER_ENABLED=true

# ── Prometheus ────────────────────────────────────────────────────────────────
# Exposed via: kubectl port-forward svc/kube-prometheus-stack-prometheus 9090:9090 -n observability
PROMETHEUS_ENABLED=true
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=30

# ── OpenTelemetry traces (Tempo) ───────────────────────────────────────────────
# Exposed via: kubectl port-forward svc/tempo 3200:3200 -n observability
OTEL_ENABLED=true
OTEL_BACKEND_TYPE=tempo
OTEL_BACKEND_URL=http://localhost:3200
OTEL_LOOKBACK_HOURS=1
OTEL_TIMEOUT=30

# ── Loki logs ─────────────────────────────────────────────────────────────────
# Exposed via: kubectl port-forward svc/loki 3100:3100 -n observability
LOKI_ENABLED=true
LOKI_URL=http://localhost:3100
LOKI_LOOKBACK_HOURS=1
LOKI_TIMEOUT=30
LOKI_MAX_LOGS_PER_POD=20

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
