# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBECONFIG=/home/user/.kube/config
KUBE_CONTEXT=default                        # leave empty to use current context
KUBE_NAMESPACES=                            # comma-separated; empty = all namespaces
KUBE_SKIP_KINDS=Event,Endpoints,EndpointSlice  # kinds to ignore during discovery

# ── Helm / Helmfile ───────────────────────────────────────────────────────────
HELMFILE_PATH=./helmfile.yaml               # path to helmfile.yaml or helmfile.d/ dir
HELMFILE_ENVIRONMENT=default               # helmfile environment to resolve values for
HELMFILE_USE_CLI=false                     # true = use `helmfile build` for full rendering

# ── Ollama / Mistral ───────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120                          # seconds

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=faiss                     # faiss | weaviate
VECTOR_STORE_PATH=./data/index.faiss
EMBEDDING_MODEL=all-MiniLM-L6-v2           # sentence-transformers model

# ── Deduplication ─────────────────────────────────────────────────────────────
BFS_MAX_DEPTH=3
JACCARD_THRESHOLD=0.7                       # chunks above this are considered duplicates
TFIDF_TOP_K=20                             # max chunks sent to LLM context
TFIDF_NGRAM_MAX=3                          # 1=unigrams 2=bigrams 3=trigrams (recommended)

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
